{
	"info": {
		"_postman_id": "recetapp-followers-api",
		"name": "RecetApp - Followers API",
		"description": "API completa para el sistema de followers de RecetApp. Incluye endpoints para seguir usuarios, obtener perfiles, listas de followers y following.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"_exporter_id": "recetapp-followers"
	},
	"item": [
		{
			"name": "🔐 Autenticación",
			"item": [
				{
					"name": "Login Usuario",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"usuario1\",\n    \"password\": \"password123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/auth/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"auth",
								"login"
							]
						},
						"description": "Endpoint para autenticar usuario y obtener sessionId"
					},
					"response": []
				},
				{
					"name": "Logout Usuario",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"sessionId\": \"{{sessionId}}\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/auth/logout",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"auth",
								"logout"
							]
						},
						"description": "Endpoint para cerrar sesión del usuario"
					},
					"response": []
				}
			],
			"description": "Endpoints de autenticación necesarios para usar la API de followers"
		},
		{
			"name": "👥 Followers - Operaciones Principales",
			"item": [
				{
					"name": "Seguir Usuario",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"followedUserId\": 2\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/follow/{{followerId}}",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"follow",
								"{{followerId}}"
							]
						},
						"description": "Hace que un usuario (followerId) siga a otro usuario (followedUserId). El usuario 1 sigue al usuario 2."
					},
					"response": []
				},
				{
					"name": "Dejar de Seguir Usuario",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/follow/{{followerId}}/{{followedId}}",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"follow",
								"{{followerId}}",
								"{{followedId}}"
							]
						},
						"description": "Hace que un usuario (followerId) deje de seguir a otro usuario (followedId)"
					},
					"response": []
				}
			],
			"description": "Endpoints principales para seguir y dejar de seguir usuarios"
		},
		{
			"name": "📊 Followers - Consultas y Perfiles",
			"item": [
				{
					"name": "Obtener Perfil de Usuario",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/follow/profile/{{userId}}?currentUserId={{currentUserId}}",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"follow",
								"profile",
								"{{userId}}"
							],
							"query": [
								{
									"key": "currentUserId",
									"value": "{{currentUserId}}",
									"description": "ID del usuario que está consultando el perfil (para saber si lo sigue)"
								}
							]
						},
						"description": "Obtiene el perfil completo de un usuario incluyendo conteo de followers, following y si el usuario actual lo sigue"
					},
					"response": []
				},
				{
					"name": "Verificar si Usuario Sigue a Otro",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/follow/{{followerId}}/isFollowing/{{followedId}}",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"follow",
								"{{followerId}}",
								"isFollowing",
								"{{followedId}}"
							]
						},
						"description": "Verifica si un usuario (followerId) sigue a otro usuario (followedId). Retorna true/false"
					},
					"response": []
				}
			],
			"description": "Endpoints para consultar perfiles y relaciones de seguimiento"
		},
		{
			"name": "📋 Followers - Listas y Conteos",
			"item": [
				{
					"name": "Obtener Lista de Usuarios que Sigue",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/follow/{{userId}}/following",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"follow",
								"{{userId}}",
								"following"
							]
						},
						"description": "Obtiene la lista completa de usuarios que sigue un usuario específico"
					},
					"response": []
				},
				{
					"name": "Obtener Lista de Seguidores",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/follow/{{userId}}/followers",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"follow",
								"{{userId}}",
								"followers"
							]
						},
						"description": "Obtiene la lista completa de seguidores de un usuario específico"
					},
					"response": []
				},
				{
					"name": "Obtener Conteo de Followers",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/follow/{{userId}}/followers/count",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"follow",
								"{{userId}}",
								"followers",
								"count"
							]
						},
						"description": "Obtiene solo el número de seguidores de un usuario (más eficiente que la lista completa)"
					},
					"response": []
				},
				{
					"name": "Obtener Conteo de Following",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/follow/{{userId}}/following/count",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"follow",
								"{{userId}}",
								"following",
								"count"
							]
						},
						"description": "Obtiene solo el número de usuarios que sigue un usuario (más eficiente que la lista completa)"
					},
					"response": []
				}
			],
			"description": "Endpoints para obtener listas y conteos de followers/following"
		},
		{
			"name": "🔧 Followers - Utilidades y Cache",
			"item": [
				{
					"name": "Limpiar Cache de Usuario",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/follow/cache/clear/{{userId}}",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"follow",
								"cache",
								"clear",
								"{{userId}}"
							]
						},
						"description": "Limpia el cache específico de un usuario (útil para testing o cuando hay inconsistencias)"
					},
					"response": []
				},
				{
					"name": "Limpiar Todo el Cache de Followers",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/follow/cache/clear/all",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"follow",
								"cache",
								"clear",
								"all"
							]
						},
						"description": "Limpia todo el cache relacionado con followers (útil para testing o mantenimiento)"
					},
					"response": []
				}
			],
			"description": "Endpoints de utilidad para manejo de cache y mantenimiento"
		},
		{
			"name": "👤 Usuarios - Gestión",
			"item": [
				{
					"name": "Crear Usuario",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"nuevoUsuario\",\n    \"email\": \"nuevo@email.com\",\n    \"password\": \"password123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/users",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"users"
							]
						},
						"description": "Crea un nuevo usuario para poder probar el sistema de followers"
					},
					"response": []
				},
				{
					"name": "Obtener Todos los Usuarios",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/users",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"users"
							]
						},
						"description": "Obtiene la lista de todos los usuarios disponibles para poder probar el sistema de followers"
					},
					"response": []
				}
			],
			"description": "Endpoints para gestionar usuarios (necesarios para probar el sistema de followers)"
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Script que se ejecuta antes de cada request",
					"console.log('Ejecutando request a: ' + pm.request.url);",
					"",
					"// Log de variables de entorno",
					"console.log('Base URL: ' + pm.environment.get('base_url'));",
					"console.log('Session ID: ' + pm.environment.get('sessionId'));"
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Script que se ejecuta después de cada response",
					"pm.test('Status code is 200, 201, or 400', function () {",
					"    pm.expect(pm.response.code).to.be.oneOf([200, 201, 400]);",
					"});",
					"",
					"pm.test('Response has required fields', function () {",
					"    const jsonData = pm.response.json();",
					"    pm.expect(jsonData).to.have.property('success');",
					"    pm.expect(jsonData).to.have.property('message');",
					"    if (jsonData.success) {",
					"        pm.expect(jsonData).to.have.property('data');",
					"    }",
					"});",
					"",
					"// Log de response para debugging",
					"console.log('Response Status: ' + pm.response.status);",
					"console.log('Response Body: ' + pm.response.text());"
				]
			}
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8080",
			"type": "string",
			"description": "URL base de la API de RecetApp"
		},
		{
			"key": "sessionId",
			"value": "",
			"type": "string",
			"description": "ID de sesión del usuario autenticado (se obtiene del login)"
		},
		{
			"key": "followerId",
			"value": "1",
			"type": "string",
			"description": "ID del usuario que va a seguir a otro"
		},
		{
			"key": "followedId",
			"value": "2",
			"type": "string",
			"description": "ID del usuario que va a ser seguido"
		},
		{
			"key": "userId",
			"value": "1",
			"type": "string",
			"description": "ID del usuario para consultas generales"
		},
		{
			"key": "currentUserId",
			"value": "1",
			"type": "string",
			"description": "ID del usuario actual que está consultando"
		}
	]
}
